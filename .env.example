# ==============================================================================
# Umeed-AI Environment Configuration Template
# ==============================================================================
# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual configuration
# 3. NEVER commit your actual .env file to version control
# ==============================================================================

# API Configuration
# Replace with a long, random, secure string (e.g., openssl rand -hex 32)
JWT_SECRET_KEY=replace_with_a_long_random_secure_secret
JWT_ALGORITHM=HS256

# Admin Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=secure_password_here

# Supabase Configuration
# SUPABASE_URL: The URL of your Supabase project
SUPABASE_URL=https://your-project-id.supabase.co

# SUPABASE_SERVICE_KEY: The "service_role" secret key.
# WARNING: This key bypasses Row Level Security (RLS). 
# It must NEVER be exposed in the frontend or committed to git.
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# SUPABASE_ANON_KEY: The "anon" public key.
SUPABASE_ANON_KEY=your_supabase_anon_key

# Database Connection (Direct)
DATABASE_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres

# Application Settings
DEBUG=True
PORT=8000
ENVIRONMENT=development
