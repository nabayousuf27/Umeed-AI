# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# ==============================================================================
# Virtual Environment
# ==============================================================================
venv/
env/
ENV/

# ==============================================================================
# Environment / Secrets (CRITICAL)
# ==============================================================================
# NEVER commit .env files to version control. They contain sensitive credentials 
# like Supabase Service Role Keys and JWT secrets. 
# Compromised Service Role Keys bypass Row Level Security (RLS) entirely.
.env
.env.*
!.env.example

*.key
*.pem
*.crt

# ==============================================================================
# IDEs / Editors
# ==============================================================================
.vscode/
.idea/

# ==============================================================================
# OS generated files
# ==============================================================================
.DS_Store
Thumbs.db

# ==============================================================================
# Logs
# ==============================================================================
*.log
*.tmp
*.bak
*.swp

# ==============================================================================
# Database / Local files
# ==============================================================================
*.sqlite3
*.db
instance/

# ==============================================================================
# Python packaging / build
# ==============================================================================
build/
dist/
*.egg-info/
.eggs/

# ==============================================================================
