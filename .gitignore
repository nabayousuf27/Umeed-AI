# ==============================================================================
htmlcov/
.coverage
.tox/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# ==============================================================================
# Supabase / Deployment
# ==============================================================================
supabase/.env
supabase/.config

# ==============================================================================
